# Port the API listens on (default 8787).
PORT=8787

# Application environment: dev | test | prod.
APP_ENV=dev

# SQLite database location (filled in Phase 2).
# DATABASE_URL=file:./.data/verifly-dev.sqlite

# Pepper for session-token / HMAC hashing (filled in Phase 5).
# SESSION_PEPPER=

# Cookie domain for session cookies.
# COOKIE_DOMAIN=localhost

# Comma-separated list of allowed origins for CORS (Phase 11.1 pulled
# forward to Phase 10 so frontends can call the API with credentials).
# The @lovable.dev Vite preset picks an ephemeral port per app during dev,
# so add an origin line per port as you run each frontend.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177

# Local object-storage directory (Phase 8).
# STORAGE_DIR=./.storage
